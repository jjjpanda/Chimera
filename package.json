{
  "name": "chimera",
  "version": "5.1.2",
  "description": "a microservices based security camera system",
  "main": "server.js",
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=22.0.0"
  },
  "workspaces": [
    "command",
    "gateway",
    "lib",
    "livestream",
    "memory",
    "object",
    "schedule",
    "storage"
  ],
  "scripts": {
    "build": "npm-run-all -s --npm-path npm \"build:*\"",
    "build:command": "npm run build --workspace=command",
    "prepare:database": "node chimera/prepareDatabase.js",
    "lint": "eslint --ext .jsx --ext .js \".\" -o eslint/lintOutput.html -f html",
    "lintfix": "eslint --ext .jsx --ext .js \".\" -o eslint/lintOutput.html -f html --fix",
    "clean": "npx --yes rimraf@latest **/log **/feed **/shared **/eslint **/coverage **/node_modules **/package-lock.json **/npm-shrinkwrap.json",
    "test": "jest",
    "e2e:install": "npm run e2e:install --workspace=command",
    "e2e:command": "npm run e2e --workspace=command",
    "devprep": "npm run prerelease && npm run build",
    "prerelease": "npm run clean && npm install",
    "release": "npm-run-all -s --npm-path npm build test",
    "postrelease": "npm install --omit=dev && npm shrinkwrap",
    "setup": "npm install && npm run build",
    "preflight": "node chimera/preflight.js",
    "predocker:build": "node chimera/preflight.js --check",
    "docker:build": "docker compose build",
    "predocker:up": "node chimera/preflight.js --check",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose restart",
    "docker:rebuild": "npm-run-all -s --npm-path npm docker:down docker:build docker:up",
    "docker:delete": "docker compose down -v"
  },
  "dependencies": {
    "command": "file:./command",
    "dotenv": "^16.4.0",
    "gateway": "file:./gateway",
    "heartbeat": "jjjpanda/heartbeat#v1.3.0",
    "lib": "file:./lib",
    "livestream": "file:./livestream",
    "memory": "file:./memory",
    "mkdirp": "^1.0.4",
    "ncp": "^2.0.0",
    "object": "file:./object",
    "npm-run-all": "^4.1.5",
    "pg": "^8.11.0",
    "pm2": "^5.4.0",
    "rimraf": "^3.0.2",
    "schedule": "file:./schedule",
    "storage": "file:./storage"
  },
  "devDependencies": {
    "eslint": "^8.2.0",
    "eslint-plugin-react": "^7.27.0",
    "jest": "^29.0.0",
    "supertest": "^6.1.6"
  }
}
